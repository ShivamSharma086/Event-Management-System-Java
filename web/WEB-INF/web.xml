<?xml version="1.0" encoding="UTF-8"?>
<web-app version="3.1"
xmlns="http://xmlns.jcp.org/xml/ns/javaee"
xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
http://xmlns.jcp.org/xml/ns/javaee/web-app_3_1.xsd">

<!-- SERVLETS -->

<servlet>
<servlet-name>ValidateAd</servlet-name>
<servlet-class>com.evently.ValidateAd</servlet-class>
</servlet>

<servlet>
<servlet-name>StoreP</servlet-name>
<servlet-class>com.evently.StoreP</servlet-class>
</servlet>

<servlet>
<servlet-name>VaPa</servlet-name>
<servlet-class>com.evently.VaPa</servlet-class>
</servlet>

<servlet>
<servlet-name>AddEvent</servlet-name>
<servlet-class>com.evently.AddEvent</servlet-class>
</servlet>

<servlet>
<servlet-name>ViewEvent1</servlet-name>
<servlet-class>com.evently.ViewEvent1</servlet-class>
</servlet>

<servlet>
<servlet-name>Register</servlet-name>
<servlet-class>com.evently.Register</servlet-class>
</servlet>

<servlet>
<servlet-name>TraH</servlet-name>
<servlet-class>com.evently.TraH</servlet-class>
</servlet>

<servlet>
<servlet-name>GenerateTicket</servlet-name>
<servlet-class>com.evently.GenerateTicket</servlet-class>
</servlet>

<servlet>
<servlet-name>VerifyTicket</servlet-name>
<servlet-class>com.evently.VerifyTicket</servlet-class>
</servlet>


<!-- SERVLET MAPPINGS -->

<servlet-mapping>
<servlet-name>ValidateAd</servlet-name>
<url-pattern>/ValidateAd</url-pattern>
</servlet-mapping>

<servlet-mapping>
<servlet-name>StoreP</servlet-name>
<url-pattern>/StoreP</url-pattern>
</servlet-mapping>

<servlet-mapping>
<servlet-name>VaPa</servlet-name>
<url-pattern>/VaPa</url-pattern>
</servlet-mapping>

<servlet-mapping>
<servlet-name>AddEvent</servlet-name>
<url-pattern>/AddEvent</url-pattern>
</servlet-mapping>

<servlet-mapping>
<servlet-name>ViewEvent1</servlet-name>
<url-pattern>/ViewEvent1</url-pattern>
</servlet-mapping>

<servlet-mapping>
<servlet-name>Register</servlet-name>
<url-pattern>/Register</url-pattern>
</servlet-mapping>

<servlet-mapping>
<servlet-name>TraH</servlet-name>
<url-pattern>/TraH</url-pattern>
</servlet-mapping>

<servlet-mapping>
<servlet-name>GenerateTicket</servlet-name>
<url-pattern>/ticket</url-pattern>
</servlet-mapping>

<servlet-mapping>
<servlet-name>VerifyTicket</servlet-name>
<url-pattern>/verifyTicket</url-pattern>
</servlet-mapping>

<!-- SESSION -->

<session-config>
<session-timeout>30</session-timeout>
</session-config>

<servlet>
    <servlet-name>PaymentSuccessServlet</servlet-name>
    <servlet-class>com.evently.PaymentSuccessServlet</servlet-class>
</servlet>

<servlet-mapping>
    <servlet-name>PaymentSuccessServlet</servlet-name>
    <url-pattern>/PaymentSuccessServlet</url-pattern>
</servlet-mapping>

</web-app>